{
  "name": "dopest-clip-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron editor for dopest-clip — the human face over the dopest_clip JSON-RPC sidecar.",
  "author": "dopest-clip",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && tsc -p electron/tsconfig.json",
    "build:electron": "tsc -p electron/tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.0.2"
  }
}
